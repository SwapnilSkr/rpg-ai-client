API_BASE_URL=http://localhost:3000
WS_BASE_URL=ws://localhost:3000
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Android dev (optional): debug/profile remap localhost -> 10.0.2.2 on emulators.
# Physical device + adb reverse: SKIP_ANDROID_LOCALHOST_REMAP=true
# Or use your machine LAN IP: ANDROID_DEV_HOST=192.168.x.x
